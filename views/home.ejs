<!DOCTYPE html>
<html>

<head>
    <title>Student Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5 text-center">
        <h1 class="mb-4 fw-bold">🎓 Student Management System</h1>

        <div class="row g-4">
            <div class="col-md-3">
                <a href="/add-student" class="btn btn-success w-100 p-3 shadow">Add Student</a>
            </div>

            <div class="col-md-3">
                <a href="/view-students" class="btn btn-primary w-100 p-3 shadow">View Students</a>
            </div>

            <div class="col-md-3">
                <a href="/update-students" class="btn btn-warning w-100 p-3 shadow">Update Students</a>
            </div>

            <div class="col-md-3">
                <a href="/search-student" class="btn btn-secondary w-100 p-3 shadow">Search Student</a>
            </div>

            <div class="col-md-3">
                <a href="/delete-students" class="btn btn-danger w-100 p-3 shadow">Delete Students</a>
            </div>
        </div>
    </div>

</body>

</html>