<!DOCTYPE html>
<html>

<head>
    <title>Students</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold text-capitalize">
                <%= mode %> Students
            </h3>
            <div>
                <a href="/" class="btn btn-secondary">Home</a>
                <a href="/add-student" class="btn btn-success">Add</a>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-body table-responsive">

                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Gender</th>
                            <th>Course</th>
                            <th>Department</th>
                            <th>Admission Date</th>

                            <% if (mode==="update" ) { %>
                                <th>Update</th>
                                <% } %>

                                    <% if (mode==="delete" ) { %>
                                        <th>Delete</th>
                                        <% } %>
                        </tr>
                    </thead>

                    <tbody>
                        <% students.forEach(s=> { %>
                            <tr>
                                <td>
                                    <%= s.id %>
                                </td>
                                <td>
                                    <%= s.name %>
                                </td>
                                <td>
                                    <%= s.email %>
                                </td>
                                <td>
                                    <%= s.phone %>
                                </td>
                                <td>
                                    <%= s.gender %>
                                </td>
                                <td>
                                    <%= s.course %>
                                </td>
                                <td>
                                    <%= s.department %>
                                </td>
                                <td>
                                    <%= s.admission_date ? new Date(s.admission_date).toLocaleDateString("en-IN") : ""
                                        %>
                                </td>

                                <% if (mode==="update" ) { %>
                                    <td>
                                        <a href="/update-student/<%= s.id %>" class="btn btn-warning btn-sm">Edit</a>
                                    </td>
                                    <% } %>

                                        <% if (mode==="delete" ) { %>
                                            <td>
                                                <a href="/delete-student/<%= s.id %>" class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Delete this student?')">
                                                    Delete
                                                </a>
                                            </td>
                                            <% } %>

                            </tr>
                            <% }) %>
                    </tbody>

                </table>

            </div>
        </div>

    </div>

</body>

</html>