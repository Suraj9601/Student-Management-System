<!DOCTYPE html>
<html>

<head>
    <title>Edit Student</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">
        <div class="card shadow p-4">
            <h4 class="mb-3">Update Student</h4>

            <form action="/update-student/<%= student.id %>" method="POST">

                <div class="row g-3">

                    <div class="col-md-6">
                        <input name="name" value="<%= student.name %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input name="email" value="<%= student.email %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input name="phone" value="<%= student.phone %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input name="gender" value="<%= student.gender %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input type="date" name="date_of_birth"
                            value="<%= student.date_of_birth ? student.date_of_birth.toISOString().split('T')[0] : '' %>"
                            class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input name="address" value="<%= student.address %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input name="department" value="<%= student.department %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input name="course" value="<%= student.course %>" class="form-control">
                    </div>

                    <div class="col-md-6">
                        <input type="date" name="admission_date"
                            value="<%= student.admission_date ? student.admission_date.toISOString().split('T')[0] : '' %>"
                            class="form-control">
                    </div>

                </div>

                <div class="mt-4 d-flex justify-content-between">
                    <a href="/update-students" class="btn btn-secondary">Back</a>
                    <button class="btn btn-warning">Update</button>
                </div>

            </form>
        </div>
    </div>

</body>

</html>